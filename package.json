{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=26.1.0"
  },
  "scripts": {
    "start": "backstage-cli repo start",
    "start:arc": "backstage-cli repo start --config ../../app-config.yaml --config ../../app-config.arc.yaml",
    "build:backend": "yarn workspace backend build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "test:e2e": "playwright test",
    "check:issue": "node scripts/check-issue-readiness.mjs",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "check:security": "node scripts/check-elliptic-cve-2025-14505.mjs",
    "new": "backstage-cli new"
  },
  "backstage": {
    "cli": {
      "new": {
        "globals": {
          "license": "UNLICENSED"
        }
      }
    }
  },
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "devDependencies": {
    "@backstage/cli": "^0.36.4-next.1",
    "@backstage/cli-defaults": "^0.1.4-next.0",
    "@backstage/e2e-test-utils": "^0.1.2",
    "@jest/environment-jsdom-abstract": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "jsdom": "^27.4.0",
    "node-gyp": "^13.0.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/request": "^10.0.11",
    "@octokit/request-error": "^7.1.0",
    "file-type": "^22.0.1",
    "prismjs": "^1.30.0",
    "isolated-vm": "^7.0.0",
    "uuid": "^14.0.1",
    "tar": "^7.5.19",
    "protobufjs": "^7.6.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "elliptic@npm:^6.5.3": "patch:elliptic@npm%3A6.6.1#~/.yarn/patches/elliptic-npm-6.6.1-87bb857cbc.patch",
    "elliptic@npm:^6.6.1": "patch:elliptic@npm%3A6.6.1#~/.yarn/patches/elliptic-npm-6.6.1-87bb857cbc.patch",
    "@material-table/core@npm:^3.1.0": "patch:@material-table/core@npm%3A3.2.5#~/.yarn/patches/@material-table-core-npm-3.2.5-5a76f950c0.patch"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
